{
  "targets": {
    "debug": {
      "textFile": "build/untouched.wat",
      "sourceMap": true,
      "debug": true,
      "outFile": "build/untouched.wasm"
    },
    "release": {
      "textFile": "build/optimized.wat",
      "sourceMap": true,
      "optimizeLevel": 3,
      "shrinkLevel": 0,
      "converge": false,
      "noAssert": false,
      "outFile": "build/optimized.wasm"
    }
  },
  "options": {
    "transform": [
      "json-as/transform"
    ],
    "bindings": "esm"
  }
}
